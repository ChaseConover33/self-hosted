#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ansible_dir="${repo_root}/ansible"
mode="${1:-deploy}"

case "${mode}" in
  bootstrap)
    playbook="playbooks/bootstrap.yml"
    ;;
  deploy)
    playbook="playbooks/deploy.yml"
    ;;
  compose)
    playbook="playbooks/compose-only.yml"
    ;;
  recover)
    playbook="playbooks/recover.yml"
    ;;
  status)
    playbook="playbooks/status.yml"
    ;;
  validate)
    playbook="playbooks/validate.yml"
    ;;
  *)
    echo "usage: $0 [bootstrap|deploy|compose|recover|status|validate]" >&2
    exit 1
    ;;
esac

cd "${ansible_dir}"

# Before deploying, clean up any stopped/dead containers on the Pi
# to prevent name conflicts when Docker Compose recreates containers.
# This is safe — it only removes containers that are already stopped.
if [[ "${mode}" == "deploy" || "${mode}" == "bootstrap" || "${mode}" == "compose" ]]; then
  echo "Cleaning up stopped containers..."
  ssh -o StrictHostKeyChecking=no \
    -i ~/.ssh/id_rsa \
    chaseconover@192.168.1.167 \
    "sudo docker container prune -f" 2>/dev/null || true
fi

ansible-playbook "${playbook}"
