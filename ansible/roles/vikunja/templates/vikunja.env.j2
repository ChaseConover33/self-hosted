# Vikunja database credentials — used by both the app and the postgres container
VIKUNJA_DATABASE_PASSWORD={{ vikunja_db_password }}
POSTGRES_USER=vikunja
POSTGRES_DB=vikunja
POSTGRES_PASSWORD={{ vikunja_db_password }}

# JWT secret — used to sign login tokens, must be kept private
VIKUNJA_SERVICE_JWTSECRET={{ vikunja_jwt_secret }}
