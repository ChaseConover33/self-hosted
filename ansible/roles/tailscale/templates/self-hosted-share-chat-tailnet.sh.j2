#!/usr/bin/env bash
set -euo pipefail

if ! command -v tailscale >/dev/null 2>&1; then
  echo "tailscale is not installed on this host." >&2
  exit 1
fi

action="${1:-status}"

case "${action}" in
  enable)
    tailscale serve --bg 8008
    echo "Synapse is now shared privately to your tailnet at the current Tailscale Serve URL."
    ;;
  disable)
    tailscale serve --bg off
    echo "Disabled Tailscale Serve for Synapse."
    ;;
  status)
    tailscale serve status
    ;;
  *)
    echo "usage: $0 [enable|disable|status]" >&2
    exit 1
    ;;
esac
