# Homelab local DNS — auto-generated by Ansible
# Maps all homelab service hostnames to this host's LAN and Tailscale IPs
# dnsmasq localise-queries returns the correct IP based on query source interface
# Do not edit manually — changes will be overwritten on next deploy
{% for service_item in platform_services | dict2items | selectattr('value.enabled') | selectattr('value.proxy_hosts', 'defined') | list %}
{% for hostname in service_item.value.proxy_hosts %}
address=/{{ hostname }}/{{ ansible_facts['default_ipv4']['address'] }}
{% if platform_tailscale_ip is defined and platform_tailscale_ip | length > 0 %}
address=/{{ hostname }}/{{ platform_tailscale_ip }}
{% endif %}
{% endfor %}
{% endfor %}
