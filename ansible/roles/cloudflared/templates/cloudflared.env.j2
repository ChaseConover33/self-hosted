# Cloudflare Tunnel credentials
#
# Generate at https://one.dash.cloudflare.com/ → Networks → Tunnels →
# "Create a tunnel" → cloudflared → name it (e.g. "homelab") → copy the
# token from the install command shown.
#
# Public hostname routing (which hostnames map to which local services)
# is configured in the dashboard under "Public Hostname" once the tunnel
# is connected. For Chronicle, route:
#   journal.chaseconover.com → http://chronicle:3000
# Do NOT route any *.lab.chaseconover.com hostnames here — those stay
# tailnet-only via Caddy.

TUNNEL_TOKEN=REPLACE_ME
